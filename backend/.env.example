# ============================================================================
# 客户服务系统后端 - 环境变量配置模板
# ============================================================================
# 说明：
# 1. 生产环境部署时，请复制此文件为 .env，并填入真实值
# 2. 或者在 Docker/K8s 部署配置中直接设置这些环境变量
# 3. ⚠️ 严禁将包含真实密码的 .env 文件提交到代码仓库！
# ============================================================================

# ----------------------------------------------------------------------------
# 数据库配置 (PostgreSQL)
# ----------------------------------------------------------------------------
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/client_service_db
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your_secure_db_password

# ----------------------------------------------------------------------------
# Redis 配置
# ----------------------------------------------------------------------------
SPRING_REDIS_HOST=redis
SPRING_REDIS_PORT=6379
# 如果 Redis 没有密码，留空即可
SPRING_REDIS_PASSWORD=your_secure_redis_password

# ----------------------------------------------------------------------------
# 安全配置 (JWT & CORS)
# ----------------------------------------------------------------------------
# JWT 签名密钥 (必须足够长且复杂，建议 32 字符以上)
# 可以使用 `openssl rand -base64 32` 生成
CLIENT_SERVICE_JWT_SECRET=your_super_secret_jwt_key_please_change_it
# JWT 过期时间 (小时)
CLIENT_SERVICE_JWT_EXPIRATION=24

# 允许跨域访问的域名 (多个域名用逗号分隔)
# 示例: https://cli.albertzhan.top,https://admin.example.com
CORS_ALLOWED_ORIGINS=https://cli.albertzhan.top

# ----------------------------------------------------------------------------
# 系统基础配置
# ----------------------------------------------------------------------------
# 系统对外访问的基础 URL (用于生成文件链接等)
BASE_URL=https://api.albertzhan.top

# Swagger 文档开关 (生产环境建议 false)
SWAGGER_ENABLED=false

# ----------------------------------------------------------------------------
# 文件存储配置 (默认 local，可选 minio)
# ----------------------------------------------------------------------------
# 存储类型: local 或 minio
FILE_STORAGE_TYPE=local
# 本地存储路径 (仅当 type=local 时生效)
FILE_STORAGE_PATH=/data/client-service/files

# MinIO 配置 (仅当 type=minio 时生效)
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key
MINIO_BUCKET=client-service
