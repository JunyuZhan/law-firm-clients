<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.clientservice.infrastructure.persistence.mapper.SysConfigMapper">

    <!-- 根据配置键查询 -->
    <select id="selectByConfigKey" resultType="com.clientservice.domain.entity.SysConfig">
        SELECT * FROM sys_config
        WHERE config_key = #{configKey}
        AND deleted = false
    </select>

</mapper>
