# =====================================================
# 客户服务系统环境变量配置示例
# =====================================================
# 复制此文件为 .env 并修改相应的配置值
# 标记为 [必填] 的配置必须修改，否则系统无法正常运行
#
# 注意：律所名称、标语、Logo、ICP备案号等前端配置已迁移至后台管理
#       部署后请在【管理后台 -> 系统配置】页面设置
# =====================================================

# -----------------------------------------------------
# 端口配置
# -----------------------------------------------------
# Nginx 对外暴露端口（默认 8080，避免与管理系统冲突）
NGINX_PORT=8080

# -----------------------------------------------------
# 数据库配置 [必填]
# -----------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here

# -----------------------------------------------------
# Redis 配置
# -----------------------------------------------------
REDIS_PASSWORD=
# Redis 数据库编号（默认 0）
SPRING_REDIS_DATABASE=0

# -----------------------------------------------------
# 应用配置 [必填]
# -----------------------------------------------------
# 系统外部访问地址（用于生成客户访问链接）
# 部署后请修改为实际地址，如：http://192.168.1.100:8080
BASE_URL=http://localhost:8080
# Spring Profile
SPRING_PROFILES_ACTIVE=prod

# -----------------------------------------------------
# 安全配置 [必填]
# -----------------------------------------------------
# JWT 密钥（生产环境必须修改为强密钥，建议使用随机生成的 64 位以上字符串）
# 生成命令：openssl rand -base64 64
JWT_SECRET=your_very_long_and_secure_jwt_secret_key_at_least_64_characters
# JWT 过期时间（小时）
JWT_EXPIRATION=24

# -----------------------------------------------------
# 律所系统回调配置
# -----------------------------------------------------
# 是否启用回调
CLIENT_SERVICE_CALLBACK_ENABLED=true
# 律所管理系统回调地址（如：http://192.168.1.100:8080/api）
LAW_FIRM_CALLBACK_URL=
# 回调 API 密钥（当律所系统没有固定 IP 时使用，需与律所系统配置一致）
CALLBACK_API_KEY=

# -----------------------------------------------------
# 文件存储配置
# -----------------------------------------------------
# 存储类型：local（本地）、minio、oss（阿里云）
FILE_STORAGE_TYPE=local
# 本地存储路径
FILE_STORAGE_PATH=/data/client-service/files

# MinIO 配置（当 FILE_STORAGE_TYPE=minio 时需要）
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key
MINIO_BUCKET=client-service
# MinIO Console 管理界面端口（运维访问）
MINIO_CONSOLE_PORT=9001

# -----------------------------------------------------
# 邮件配置（可选，启用邮件通知时需要）
# -----------------------------------------------------
# 注意：邮件 SMTP 配置应在后台"系统配置"中管理，而非环境变量
# 配置路径：管理后台 -> 系统配置 -> 添加以下配置项：
#   - notification.email.enabled (BOOLEAN)
#   - client-service.notification.email.from (STRING)
#   - client-service.notification.email.from-name (STRING)
# 
# SMTP 服务器配置需要在 application.yml 中设置（作为兜底配置），
# 但建议通过后台"系统配置"管理，避免修改代码
# SPRING_MAIL_HOST=smtp.example.com
# SPRING_MAIL_PORT=587
# SPRING_MAIL_USERNAME=
# SPRING_MAIL_PASSWORD=

# -----------------------------------------------------
# OnlyOffice 配置（可选，启用文档预览/编辑时需要）
# -----------------------------------------------------
# OnlyOffice JWT 密钥（必须配置，防止未授权访问）
# 生成命令：openssl rand -base64 32
# 注意：此密钥需要在后端代码中使用，生成签名的文档配置
ONLYOFFICE_JWT_SECRET=your_onlyoffice_jwt_secret_at_least_32_chars

# -----------------------------------------------------
# 日志配置（可选）
# -----------------------------------------------------
# 日志文件路径（默认：logs）
# LOG_PATH=logs
# 日志文件名（默认：client-service）
# LOG_FILE=client-service
# Loki 服务地址（可选，用于日志收集）
# LOKI_URL=http://localhost:3100/loki/api/v1/push

# -----------------------------------------------------
# 其他配置
# -----------------------------------------------------
# 是否启用 Swagger UI（生产环境建议关闭）
SWAGGER_ENABLED=false

# 访问日志保留天数
CLIENT_SERVICE_ACCESS_LOG_RETENTION_DAYS=90

# -----------------------------------------------------
# 版本检查配置（可选，用于升级提示）
# -----------------------------------------------------
# 方式一：自定义版本检查 URL
# 需要返回 JSON: {"version": "1.2.0", "releaseNotes": "...", "releaseUrl": "..."}
# APP_VERSION_CHECK_URL=https://your-server.com/api/version/latest

# 方式二：GitHub 仓库（从 GitHub Releases 获取最新版本）
# 格式: owner/repo
APP_VERSION_GITHUB_REPO=junyuzhan/law-firm
