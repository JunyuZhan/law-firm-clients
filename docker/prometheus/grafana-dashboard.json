{
  "dashboard": {
    "title": "客户服务系统监控仪表板",
    "tags": ["client-service", "spring-boot"],
    "timezone": "browser",
    "schemaVersion": 16,
    "version": 1,
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "服务状态",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "up{job=\"client-service-backend\"}",
            "legendFormat": "服务状态"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                {"value": 0, "color": "red"},
                {"value": 1, "color": "green"}
              ]
            }
          }
        }
      },
      {
        "id": 2,
        "title": "API请求量 (QPS)",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 6, "y": 0},
        "targets": [
          {
            "expr": "rate(http_server_requests_seconds_count{job=\"client-service-backend\",uri!~\"/actuator.*\"}[5m])",
            "legendFormat": "{{uri}}"
          }
        ],
        "yaxes": [
          {"format": "reqps", "label": "请求/秒"}
        ]
      },
      {
        "id": 3,
        "title": "API响应时间",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
        "targets": [
          {
            "expr": "rate(http_server_requests_seconds_sum{job=\"client-service-backend\",uri=\"/api/matter/receive\"}[5m]) / rate(http_server_requests_seconds_count{job=\"client-service-backend\",uri=\"/api/matter/receive\"}[5m])",
            "legendFormat": "接收项目数据"
          },
          {
            "expr": "rate(http_server_requests_seconds_sum{job=\"client-service-backend\",uri=~\"/portal/api/matter/.*\"}[5m]) / rate(http_server_requests_seconds_count{job=\"client-service-backend\",uri=~\"/portal/api/matter/.*\"}[5m])",
            "legendFormat": "客户门户"
          },
          {
            "expr": "rate(http_server_requests_seconds_sum{job=\"client-service-backend\",uri=\"/api/client/files/upload\"}[5m]) / rate(http_server_requests_seconds_count{job=\"client-service-backend\",uri=\"/api/client/files/upload\"}[5m])",
            "legendFormat": "文件上传"
          }
        ],
        "yaxes": [
          {"format": "s", "label": "响应时间(秒)"}
        ]
      },
      {
        "id": 4,
        "title": "错误率",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
        "targets": [
          {
            "expr": "rate(http_server_requests_seconds_count{job=\"client-service-backend\",status=~\"5..\"}[5m]) / rate(http_server_requests_seconds_count{job=\"client-service-backend\"}[5m]) * 100",
            "legendFormat": "5xx错误率"
          },
          {
            "expr": "rate(http_server_requests_seconds_count{job=\"client-service-backend\",status=~\"4..\"}[5m]) / rate(http_server_requests_seconds_count{job=\"client-service-backend\"}[5m]) * 100",
            "legendFormat": "4xx错误率"
          }
        ],
        "yaxes": [
          {"format": "percent", "label": "错误率(%)"}
        ]
      },
      {
        "id": 5,
        "title": "JVM内存使用",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
        "targets": [
          {
            "expr": "jvm_memory_used_bytes{job=\"client-service-backend\",area=\"heap\"} / jvm_memory_max_bytes{job=\"client-service-backend\",area=\"heap\"} * 100",
            "legendFormat": "堆内存使用率"
          }
        ],
        "yaxes": [
          {"format": "percent", "label": "使用率(%)", "max": 100}
        ]
      },
      {
        "id": 6,
        "title": "数据库连接池",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
        "targets": [
          {
            "expr": "hikari_connections_active{job=\"client-service-backend\"}",
            "legendFormat": "活跃连接"
          },
          {
            "expr": "hikari_connections_idle{job=\"client-service-backend\"}",
            "legendFormat": "空闲连接"
          },
          {
            "expr": "hikari_connections_pending{job=\"client-service-backend\"}",
            "legendFormat": "等待连接"
          }
        ],
        "yaxes": [
          {"format": "short", "label": "连接数"}
        ]
      },
      {
        "id": 7,
        "title": "GC暂停时间",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
        "targets": [
          {
            "expr": "rate(jvm_gc_pause_seconds_sum{job=\"client-service-backend\"}[5m])",
            "legendFormat": "{{gc}}"
          }
        ],
        "yaxes": [
          {"format": "s", "label": "暂停时间(秒)"}
        ]
      },
      {
        "id": 8,
        "title": "线程数",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
        "targets": [
          {
            "expr": "jvm_threads_live_threads{job=\"client-service-backend\"}",
            "legendFormat": "活跃线程"
          },
          {
            "expr": "jvm_threads_daemon_threads{job=\"client-service-backend\"}",
            "legendFormat": "守护线程"
          }
        ],
        "yaxes": [
          {"format": "short", "label": "线程数"}
        ]
      }
    ],
    "time": {
      "from": "now-6h",
      "to": "now"
    },
    "timepicker": {
      "refresh_intervals": ["10s", "30s", "1m", "5m", "15m", "30m", "1h", "2h", "1d"]
    }
  }
}
